# ============================================
# GEO VISION Frontend — Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# Vite requires VITE_ prefix for client-exposed vars

# Backend API URL (your Render deployment URL)
VITE_API_URL=https://your-backend.onrender.com

# Optional alias used by some services; if omitted, VITE_API_URL is used.
VITE_BACKEND_URL=https://your-backend.onrender.com

# HazardGuard service URL (same as main API)
VITE_HAZARDGUARD_URL=https://your-backend.onrender.com
